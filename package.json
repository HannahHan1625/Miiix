{
  "name": "miiix-fridge-fusion",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:migrations": "node scripts/check-migrations.mjs",
